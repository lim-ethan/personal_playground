   "source": [
    "def solution(n):\n",
    "    MOD = 1000000007\n",
    "    dp = [0] * (n+1)\n",
    "    dp[1] = 1\n",
    "    dp[2] = 2\n",
    "    print(dp)\n",
    "    for i in range(3, n+1):\n",
    "        dp[i] = (dp[i-1] + dp[i-2]) % MOD\n",
    "    print(dp)\n",
    "    return dp[n]\n"
   ]
  },
